<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<script>
const tc='rgba(0,0,0,.45)', gc='rgba(0,0,0,.07)';
const P=['#378ADD','#534AB7','#0F6E56','#BA7517','#A32D2D','#639922','#D4537E'];
const rendered={};

function show(id,btn){
  document.querySelectorAll('.panel').forEach(p=>p.classList.remove('on'));
  document.querySelectorAll('.tab').forEach(b=>b.classList.remove('active'));
  document.getElementById(id).classList.add('on');
  btn.classList.add('active');
  setTimeout(()=>draw(id),50);
}

function draw(id){
  if(rendered[id])return; rendered[id]=true;
  const bo={responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},
            scales:{x:{ticks:{color:tc},grid:{color:gc}},y:{ticks:{color:tc},grid:{color:gc}}}};

  if(id==='intro'){
    const rng=(s)=>{let v=s;return()=>{v=(v*1664525+1013904223)&0x7fffffff;return v/0x7fffffff;}};
    const r=rng(7), n=80;
    const c0=Array.from({length:n},()=>({x:r()*4-4,y:r()*4-2}));
    const c1=Array.from({length:n},()=>({x:r()*4, y:r()*4-2}));
    new Chart(document.getElementById('cIntro'),{type:'scatter',data:{datasets:[
      {label:'Clase 0',data:c0,backgroundColor:'rgba(55,138,221,.5)',pointRadius:4},
      {label:'Clase 1',data:c1,backgroundColor:'rgba(163,45,45,.5)',pointRadius:4},
    ]},options:{...bo,plugins:{legend:{display:false}}}});
  }

  if(id==='tipos'){
    new Chart(document.getElementById('cTipos'),{type:'bar',
      data:{labels:['Reg. Logística','SVM (RBF)','KNN','Árbol','Random Forest','XGBoost','Naive Bayes'],
            datasets:[{data:[0.84,0.87,0.82,0.78,0.91,0.93,0.76],backgroundColor:P,borderRadius:4}]},
      options:{...bo,scales:{
        x:{ticks:{color:tc,maxRotation:20},grid:{color:'transparent'}},
        y:{min:0.5,max:1,ticks:{color:tc,callback:v=>(v*100).toFixed(0)+'%'},grid:{color:gc},
           title:{display:true,text:'Accuracy',color:tc}}}}});
  }

  if(id==='metricas'){
    const labels=['Reg. Logística','SVM','KNN','Árbol','Rand. Forest','XGBoost','Naive Bayes'];
    const acc=[0.84,0.87,0.82,0.78,0.91,0.93,0.76];
    const f1 =[0.83,0.86,0.81,0.76,0.90,0.92,0.74];
    const auc=[0.91,0.93,0.88,0.82,0.96,0.97,0.84];
    new Chart(document.getElementById('cMetricas'),{type:'bar',data:{labels,datasets:[
      {label:'Accuracy',  data:acc, backgroundColor:'rgba(55,138,221,.7)', borderRadius:3},
      {label:'F1-Score',  data:f1,  backgroundColor:'rgba(83,74,183,.7)',  borderRadius:3},
      {label:'ROC-AUC',   data:auc, backgroundColor:'rgba(15,110,86,.7)',  borderRadius:3},
    ]},options:{...bo,scales:{
      x:{ticks:{color:tc,maxRotation:20},grid:{color:'transparent'}},
      y:{min:0.5,max:1,ticks:{color:tc,callback:v=>(v*100).toFixed(0)+'%'},grid:{color:gc}}}}});
    const leg=document.getElementById('metLeg');
    [['#378ADD','Accuracy'],['#534AB7','F1-Score'],['#0F6E56','ROC-AUC']].forEach(([c,n])=>
      leg.innerHTML+=`<span><span class="ls" style="background:${c}"></span>${n}</span>`);
  }

  if(id==='comparativa'){
    const cats=['Interpretabilidad','Velocidad','Precisión','Robustez desbalance','Alta dimensión','No lineal'];
    const ms=[
      {n:'Reg. Logística',v:[10,10,5,6,7,1],c:P[0]},
      {n:'SVM',           v:[4,5,7,5,8,8],  c:P[1]},
      {n:'Random Forest', v:[5,6,9,8,7,9],  c:P[2]},
      {n:'XGBoost',       v:[3,5,10,8,8,10],c:P[3]},
      {n:'Naive Bayes',   v:[7,10,5,5,7,3], c:P[4]},
    ];
    new Chart(document.getElementById('cRadar'),{type:'radar',data:{labels:cats,
      datasets:ms.map(m=>({label:m.n,data:m.v,borderColor:m.c,backgroundColor:m.c+'15',borderWidth:2,pointBackgroundColor:m.c}))},
      options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},
               scales:{r:{min:0,max:10,ticks:{display:false},grid:{color:gc},pointLabels:{color:tc,font:{size:10}}}}}});
    const leg=document.getElementById('radarLeg');
    ms.forEach(m=>leg.innerHTML+=`<span><span class="ls" style="background:${m.c}"></span>${m.n}</span>`);
  }
}
draw('intro');
</script>
</body>
</html>
