<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<script>
const tc='rgba(0,0,0,.45)',gc='rgba(0,0,0,.07)';
const P=['#378ADD','#534AB7','#0F6E56','#BA7517','#A32D2D','#639922','#D4537E'];
const rendered={};
function show(id,btn){
  document.querySelectorAll('.panel').forEach(p=>p.classList.remove('on'));
  document.querySelectorAll('.tab').forEach(b=>b.classList.remove('active'));
  document.getElementById(id).classList.add('on');btn.classList.add('active');
  setTimeout(()=>draw(id),50);
}
function draw(id){
  if(rendered[id])return;rendered[id]=true;
  const bo={responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},
            scales:{x:{ticks:{color:tc},grid:{color:gc}},y:{ticks:{color:tc},grid:{color:gc}}}};

  if(id==='intro'){
    const eps=Array.from({length:40},(_,i)=>i+1);
    const tl=eps.map(e=>Math.max(.08,2.2*Math.exp(-.07*e)+.08));
    const vl=eps.map(e=>Math.max(.22,2.0*Math.exp(-.055*e)+.25));
    new Chart(document.getElementById('cIntro'),{type:'line',data:{labels:eps,datasets:[
      {data:tl,borderColor:P[0],borderWidth:2,pointRadius:0,fill:false,label:'Train loss'},
      {data:vl,borderColor:P[4],borderWidth:2,pointRadius:0,fill:false,borderDash:[5,3],label:'Val loss'},
    ]},options:{...bo,scales:{x:{ticks:{color:tc},grid:{color:gc},title:{display:true,text:'Época',color:tc}},
      y:{ticks:{color:tc},grid:{color:gc},title:{display:true,text:'Loss',color:tc}}}}});
    const leg=document.getElementById('introLeg');
    [['#378ADD','Train loss'],['#A32D2D','Val loss']].forEach(([c,n])=>
      leg.innerHTML+=`<span><span class="ls" style="background:${c}"></span>${n}</span>`);
  }

  if(id==='activ'){
    const x=Array.from({length:100},(_,i)=>-5+i*.1);
    const relu=x.map(v=>Math.max(0,v));
    const sig=x.map(v=>1/(1+Math.exp(-v)));
    const tanh=x.map(v=>Math.tanh(v));
    const lrelu=x.map(v=>v>0?v:.1*v);
    const gelu=x.map(v=>v*.5*(1+Math.tanh(Math.sqrt(2/Math.PI)*(v+.044715*v**3))));
    new Chart(document.getElementById('cActiv'),{type:'line',data:{labels:x.map(v=>v.toFixed(1)),datasets:[
      {data:relu, borderColor:P[0],borderWidth:2,pointRadius:0,fill:false},
      {data:sig,  borderColor:P[1],borderWidth:2,pointRadius:0,fill:false},
      {data:tanh, borderColor:P[2],borderWidth:2,pointRadius:0,fill:false},
      {data:lrelu,borderColor:P[3],borderWidth:2,pointRadius:0,fill:false,borderDash:[5,3]},
      {data:gelu, borderColor:P[4],borderWidth:2,pointRadius:0,fill:false,borderDash:[2,4]},
    ]},options:{...bo,scales:{x:{ticks:{color:tc,maxTicksLimit:11},grid:{color:gc}},y:{min:-1.5,max:3,ticks:{color:tc},grid:{color:gc}}}}});
  }

  if(id==='reg'){
    const eps=Array.from({length:60},(_,i)=>i+1);
    const tr=eps.map(e=>Math.max(.05,2.2*Math.exp(-.06*e)+.05));
    const vn=eps.map(e=>e<20?tr[e-1]+.1:Math.min(2.5,tr[e-1]+.02*(e-20)+.1));
    const vr=eps.map(e=>Math.max(.25,2.0*Math.exp(-.05*e)+.3));
    new Chart(document.getElementById('cReg'),{type:'line',data:{labels:eps,datasets:[
      {data:tr,borderColor:P[0],borderWidth:2,pointRadius:0,fill:false},
      {data:vn,borderColor:P[4],borderWidth:2,pointRadius:0,fill:false,borderDash:[5,3]},
      {data:vr,borderColor:P[2],borderWidth:2,pointRadius:0,fill:false},
    ]},options:{...bo,scales:{x:{ticks:{color:tc,maxTicksLimit:10},grid:{color:gc},title:{display:true,text:'Época',color:tc}},
      y:{ticks:{color:tc},grid:{color:gc},title:{display:true,text:'Loss',color:tc}}}}});
  }

  if(id==='tipos'){
    const cats=['Datos tabulares','Imágenes','Texto/NLP','Series temp.','Generación','Interpretabilidad'];
    const ms=[
      {n:'MLP',        v:[9,4,5,6,3,8],  c:P[0]},
      {n:'CNN',        v:[4,10,5,5,6,6], c:P[1]},
      {n:'LSTM/GRU',   v:[4,3,8,9,4,5], c:P[2]},
      {n:'Transformer',v:[5,7,10,8,7,4], c:P[3]},
      {n:'VAE/GAN',    v:[3,5,5,4,10,3], c:P[4]},
    ];
    new Chart(document.getElementById('cTipos'),{type:'radar',data:{labels:cats,
      datasets:ms.map(m=>({label:m.n,data:m.v,borderColor:m.c,backgroundColor:m.c+'15',borderWidth:2,pointBackgroundColor:m.c}))},
      options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},
               scales:{r:{min:0,max:10,ticks:{display:false},grid:{color:gc},pointLabels:{color:tc,font:{size:10}}}}}});
    const leg=document.getElementById('tiposLeg');
    ms.forEach(m=>leg.innerHTML+=`<span><span class="ls" style="background:${m.c}"></span>${m.n}</span>`);
  }

  if(id==='metricas'){
    const eps=Array.from({length:50},(_,i)=>i+1);
    const tl=eps.map(e=>Math.max(.08,2.0*Math.exp(-.07*e)+.08));
    const vl=eps.map(e=>Math.max(.25,1.9*Math.exp(-.055*e)+.28));
    const ta=eps.map(e=>Math.min(.99,.4+.58*(1-Math.exp(-.07*e))));
    const va=eps.map(e=>Math.min(.94,.38+.54*(1-Math.exp(-.055*e))));
    new Chart(document.getElementById('cMetricas'),{type:'line',data:{labels:eps,datasets:[
      {data:tl,borderColor:P[0],borderWidth:2,pointRadius:0,fill:false,yAxisID:'y'},
      {data:vl,borderColor:P[1],borderWidth:2,pointRadius:0,fill:false,borderDash:[5,3],yAxisID:'y'},
      {data:ta,borderColor:P[2],borderWidth:2,pointRadius:0,fill:false,yAxisID:'y2'},
      {data:va,borderColor:P[3],borderWidth:2,pointRadius:0,fill:false,borderDash:[2,4],yAxisID:'y2'},
    ]},options:{...bo,scales:{
      x:{ticks:{color:tc,maxTicksLimit:10},grid:{color:gc},title:{display:true,text:'Época',color:tc}},
      y:{ticks:{color:tc},grid:{color:gc},title:{display:true,text:'Loss',color:tc}},
      y2:{type:'linear',position:'right',min:0,max:1,ticks:{color:tc},grid:{display:false},title:{display:true,text:'Accuracy',color:tc}}
    }}});
  }

  if(id==='comparativa'){
    const cats=['Interpretabilidad','Velocidad entren.','Precisión tabular','Robustez outliers','Alta dimensión','No lineal'];
    const ms=[
      {n:'MLP',         v:[7,9,7,6,7,6],  c:P[0]},
      {n:'CNN',         v:[5,8,8,7,8,9],  c:P[1]},
      {n:'LSTM/GRU',    v:[4,5,7,6,7,8],  c:P[2]},
      {n:'Transformer', v:[3,4,9,6,9,10], c:P[3]},
      {n:'Autoencoder', v:[4,6,6,8,7,8],  c:P[4]},
    ];
    new Chart(document.getElementById('cRadar'),{type:'radar',data:{labels:cats,
      datasets:ms.map(m=>({label:m.n,data:m.v,borderColor:m.c,backgroundColor:m.c+'15',borderWidth:2,pointBackgroundColor:m.c}))},
      options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},
               scales:{r:{min:0,max:10,ticks:{display:false},grid:{color:gc},pointLabels:{color:tc,font:{size:10}}}}}});
    const leg=document.getElementById('radarLeg');
    ms.forEach(m=>leg.innerHTML+=`<span><span class="ls" style="background:${m.c}"></span>${m.n}</span>`);
  }
}
draw('intro');
</script>
</body>
</html>
